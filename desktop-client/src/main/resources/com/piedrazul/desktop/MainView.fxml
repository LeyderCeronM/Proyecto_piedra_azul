<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.piedrazul.desktop.MainController" spacing="12">
      
    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <Label text="Piedrazul — Cliente Desktop" style="-fx-font-size:18px; -fx-font-weight:bold;"/>

    <HBox spacing="12">
        <VBox spacing="8" HBox.hgrow="ALWAYS">
            <Label text="Probar Gateway y Reportes" style="-fx-font-size:14px; -fx-font-weight:600;"/>
            <HBox spacing="8">
                <Button fx:id="btnCheckReports" text="Obtener estadísticas" onAction="#onCheckReports" />
            </HBox>
            <TextArea fx:id="reportsTextArea" prefHeight="200" VBox.vgrow="ALWAYS"/>
        </VBox>

        <VBox spacing="8" prefWidth="320">
            <Label text="Probar Citas" style="-fx-font-size:14px; -fx-font-weight:600;"/>
            <HBox spacing="8">
                <Button fx:id="btnListAppointments" text="Listar citas" onAction="#onListAppointments" />
            </HBox>
            <ListView fx:id="appointmentsListView" prefHeight="200" />
        </VBox>
    </HBox>

    <Region VBox.vgrow="ALWAYS"/>
</VBox>