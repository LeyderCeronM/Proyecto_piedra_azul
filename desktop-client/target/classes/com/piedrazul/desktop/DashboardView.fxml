<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.piedrazul.desktop.DashboardController">

    <left>
        <VBox spacing="10" style="-fx-padding:12; -fx-background-color:#2c3e50;" prefWidth="220">
            <Label text="Piedrazul" style="-fx-text-fill: white; -fx-font-size:16px; -fx-padding:6 0 12 0;"/>
            <Button text="Gestionar Citas" onAction="#onManageAppointments" />
            <Button text="Historiales Clínicos" onAction="#onClinicalRecords" />
            <Button text="Red de Servicios" onAction="#onNetwork" />
            <Region VBox.vgrow="ALWAYS" />
            <Button text="Cerrar Sesión" onAction="#onLogout" />
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" />
    </center>

</BorderPane>
