@startuml ClassDiagram
' ====================================================================
' Class Diagram - Reference Example (format reference only)
' This file is a style reference. It does NOT reflect current users-service code.
' ====================================================================

skinparam classAttributeIconSize 0
skinparam defaultFontName SansSerif

package "com.example" as exPkg #F0F0F0 {

  class Product <<entity>> #FFFACD;line:Black {
    {field} -id: Long
    {field} -name: String
  }

  interface Builder <<interface>> #F0F8FF;line:blue {
    {method} +build(): void
    {method} +getResult(): Product
  }

  class ConcreteBuilder <<builder>> #90EE90;line:Black {
    {method} +build(): void
    {method} +getResult(): Product
  }

  class Director <<director>> #F5DEB3;line:Black {
    {method} +construct(): Product
  }

}

Builder <|.. ConcreteBuilder : "implements"
Director ..> Builder : "uses"
ConcreteBuilder ..> Product : "creates"

note bottom of Builder
  **Builder Pattern**
  Defines the construction
  interface for creating
  complex objects.
end note

@enduml
